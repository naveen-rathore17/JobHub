<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JobPortal</title>
<link rel="icon" href="/images/jobhub_favicon.ico" type="image/x-icon">
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-50 overflow-x-hidden">

<!-- NAVBAR -->
<nav class="bg-white/95 backdrop-blur-lg fixed w-full z-50 border-b">
<div class="max-w-7xl mx-auto px-6 py-2 flex justify-between items-center">

<!-- LOGO (BADA) -->
<div class="flex items-center">
<img src="/images/logo.svg" alt="JOBHUB Logo"
class="h-16 md:h-20 w-auto object-contain">
</div>

<!-- MENU -->
<div class="space-x-6 hidden md:flex items-center">

<a href="/" class="hover:text-indigo-600">Home</a>
<a href="/jobs" class="hover:text-indigo-600">Jobs</a>

<% if(!user){ %>

<a href="/login" class="hover:text-indigo-600">Login</a>

<a href="/register"
class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-500 transition">
Register
</a>

<% } else { %>

<a href="/user-dashboard"
class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-500 transition">
Account
</a>


<% } %>

</div>

<!-- MOBILE -->
<button id="menuBtn" class="md:hidden text-2xl">☰</button>

</div>

<!-- MOBILE MENU -->
<div id="mobileMenu"
class="hidden md:hidden absolute right-6 top-20 w-64 bg-white rounded-xl shadow-lg p-4 space-y-3 text-center">

<a href="/" class="block hover:text-indigo-600">Home</a>
<a href="/jobs" class="block hover:text-indigo-600">Jobs</a>
<% if(!user){ %>

<a href="/login" class="block hover:text-indigo-600">Login</a>
<a href="/register" class="block bg-indigo-600 text-white py-2 rounded-lg">Register</a>

<% } else { %>

<a href="/user-dashboard" class="block hover:text-indigo-600">
Account
</a>


<% } %>

</div>
</nav>

<!-- HERO -->
<section class="relative text-center py-36 text-white">

<!-- Background Image -->
<div class="absolute inset-0">
<img src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d"
class="w-full h-full object-cover">
<div class="absolute inset-0 bg-indigo-900/80"></div>
</div>

<div class="relative z-10 max-w-3xl mx-auto px-6">
<h1 class="text-4xl md:text-6xl font-bold">Find Your Dream Job</h1>
<p class="mt-4 text-gray-200">Thousands of opportunities waiting for you</p>

<form action="/search" method="GET" class="mt-8 flex shadow-lg rounded-lg overflow-hidden">
<input type="text" name="q" placeholder="Search jobs..."
class="w-full px-4 py-3 text-black focus:outline-none"/>
<button class="bg-indigo-600 px-6 font-semibold hover:bg-indigo-500">
Search
</button>
</form>

<a href="/jobs" class="mt-6 inline-block bg-white text-indigo-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100">
Browse Jobs
</a>
</div>
</section>

<!-- JOBS -->
<section class="max-w-7xl mx-auto px-6 py-20">
<h2 class="text-3xl font-bold text-center mb-12">Latest Opportunities</h2>

<div class="grid sm:grid-cols-2 md:grid-cols-3 gap-8">

<% jobs.slice(0,3).forEach(job=>{ %>
<div class="bg-white p-6 rounded-xl shadow-sm hover:shadow-md transition">

<h3 class="text-lg font-semibold text-indigo-600">
<%= job.title %>
</h3>

<p class="text-gray-700 mt-2">🏢 <%= job.company %></p>
<p class="text-gray-500 text-sm">📍 <%= job.location %></p>

<a href="/jobs/<%= job._id %>" class="inline-block mt-4 text-indigo-600 font-semibold">
View Details →
</a>

</div>
<% }) %>

</div>
</section>

<!-- TOP COMPANIES -->
<section class="py-20 relative overflow-hidden">

<!-- Background Image -->
<div class="absolute inset-0 -z-10">
  <img src="https://images.unsplash.com/photo-1551434678-e076c223a692?q=80&w=2070&auto=format&fit=crop" 
       class="w-full h-full object-cover opacity-40" />
</div>

<!-- Dark Overlay -->
<div class="absolute inset-0 -z-10 bg-black/30"></div>

<h2 class="text-4xl md:text-5xl font-extrabold text-center mb-14 text-yellow-300 relative z-10 
           drop-shadow-[0_5px_20px_rgba(0,0,0,0.8)]">

  TOP COMPANIES

  <div class="w-20 h-1 bg-indigo-400 mx-auto mt-4 rounded-full"></div>

</h2>

<div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 px-6">

<!-- Google -->
<div class="group bg-white/90 backdrop-blur-md p-6 rounded-2xl border border-gray-200 
            flex items-center justify-center 
            hover:shadow-2xl transition duration-500 transform hover:-translate-y-2">

  <img src="https://upload.wikimedia.org/wikipedia/commons/2/2f/Google_2015_logo.svg" 
       class="h-10 transition duration-300 group-hover:scale-110" />
</div>

<!-- Amazon -->
<div class="group bg-white/90 backdrop-blur-md p-6 rounded-2xl border border-gray-200 
            flex items-center justify-center 
            hover:shadow-2xl transition duration-500 transform hover:-translate-y-2">

  <img src="https://upload.wikimedia.org/wikipedia/commons/a/a9/Amazon_logo.svg" 
       class="h-10 transition duration-300 group-hover:scale-110" />
</div>

<!-- Microsoft -->
<div class="group bg-white/90 backdrop-blur-md p-6 rounded-2xl border border-gray-200 
            flex items-center justify-center 
            hover:shadow-2xl transition duration-500 transform hover:-translate-y-2">

  <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg" 
       class="h-10 transition duration-300 group-hover:scale-110" />
</div>

<!-- Infosys -->
<div class="group bg-white/90 backdrop-blur-md p-6 rounded-2xl border border-gray-200 
            flex items-center justify-center 
            hover:shadow-2xl transition duration-500 transform hover:-translate-y-2">

  <img src="https://upload.wikimedia.org/wikipedia/commons/9/95/Infosys_logo.svg" 
       class="h-10 transition duration-300 group-hover:scale-110" />
</div>

</div>

</section>

<!-- HOW IT WORKS -->
<section class="py-20 relative">

<!-- Background Glow -->
<div class="absolute left-1/2 -translate-x-1/2 w-[400px] h-[400px] bg-indigo-400 opacity-20 blur-3xl rounded-full -z-10"></div>

<h2 class="text-4xl font-bold text-center mb-14 text-gray-900">
  How It Works
</h2>

<div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-10 px-6 text-center">

<!-- Step 1 -->
<div class="group bg-white/80 backdrop-blur-lg p-8 rounded-2xl shadow-md border border-gray-200 
            hover:shadow-2xl transition duration-500 transform hover:-translate-y-2 hover:scale-[1.03]">

  <div class="text-4xl mb-4 group-hover:scale-110 transition">👤</div>

  <h3 class="font-semibold text-lg text-gray-900 group-hover:text-indigo-600 transition">
    Create Account
  </h3>

  <p class="text-gray-500 mt-2">
    Sign up and build your profile
  </p>

</div>

<!-- Step 2 -->
<div class="group bg-white/80 backdrop-blur-lg p-8 rounded-2xl shadow-md border border-gray-200 
            hover:shadow-2xl transition duration-500 transform hover:-translate-y-2 hover:scale-[1.03]">

  <div class="text-4xl mb-4 group-hover:scale-110 transition">📄</div>

  <h3 class="font-semibold text-lg text-gray-900 group-hover:text-indigo-600 transition">
    Upload Resume
  </h3>

  <p class="text-gray-500 mt-2">
    Add your resume
  </p>

</div>

<!-- Step 3 -->
<div class="group bg-white/80 backdrop-blur-lg p-8 rounded-2xl shadow-md border border-gray-200 
            hover:shadow-2xl transition duration-500 transform hover:-translate-y-2 hover:scale-[1.03]">

  <div class="text-4xl mb-4 group-hover:scale-110 transition">🚀</div>

  <h3 class="font-semibold text-lg text-gray-900 group-hover:text-indigo-600 transition">
    Apply Jobs
  </h3>

  <p class="text-gray-500 mt-2">
    Start applying instantly
  </p>

</div>

</div>

</section>

<!-- STATS (Same Indigo Background - Improved UI) -->
<section class="bg-indigo-600 text-white py-20 text-center mt-2">
<div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-10">

<div>
<h2 class="text-3xl font-bold">10K+</h2>
<p class="text-gray-200 mt-1">Jobs Posted</p>
</div>

<div>
<h2 class="text-3xl font-bold">5K+</h2>
<p class="text-gray-200 mt-1">Companies</p>
</div>

<div>
<h2 class="text-3xl font-bold">8K+</h2>
<p class="text-gray-200 mt-1">Successful Hires</p>
</div>

<div>
<h2 class="text-3xl font-bold">20K+</h2>
<p class="text-gray-200 mt-1">Active Users</p>
</div>

</div>
</section>

<div class="h-16 bg-gradient-to-b from-indigo-600 to-yellow-400"></div>

<!-- CTA (Yellow Highlight Section - More Content Added) -->
<section class="bg-yellow-400 text-center py-20 px-6 ">

<h2 class="text-3xl md:text-4xl font-bold text-gray-900">
Start Your Career Journey Today 🚀
</h2>

<p class="mt-4 text-gray-800 max-w-2xl mx-auto">
Join thousands of job seekers who found their dream jobs through our platform.
Create your profile, upload your resume, and apply to top companies in just a few clicks.
</p>

<div class="mt-8 flex flex-col md:flex-row justify-center gap-4">

<a href="/register"
class="bg-black text-white px-8 py-3 rounded-lg font-semibold hover:bg-gray-800 transition">
Create Account
</a>

<a href="/jobs"
class="bg-white text-black px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">
Browse Jobs
</a>

</div>

</section>


<!-- FOOTER (Professional Multi-Column Footer) -->
<footer class="bg-gray-900 text-gray-400 py-12">
<p class="text-sm text-center">
Contact: <a href="mailto:support@jobportal.com" class="hover:text-white">support@jobportal.com</a>
</p>

<!-- Bottom -->
<div class="text-center text-xs text-gray-500 mt-8 border-t border-gray-800 pt-6">
© 2026 JobPortal. All rights reserved.
</div>

</footer>
<script>
const btn = document.getElementById("menuBtn");
const menu = document.getElementById("mobileMenu");

btn.addEventListener("click", (e) => {
  e.stopPropagation();
  menu.classList.toggle("hidden");
});

document.addEventListener("click", (e) => {
  if (!menu.contains(e.target) && !btn.contains(e.target)) {
    menu.classList.add("hidden");
  }
});
</script>

</body>
</html>