<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Profile — <%= user.name %></title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  body { font-family: 'Inter', sans-serif; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes scaleIn {
    from { opacity: 0; transform: scale(0.85); }
    to   { opacity: 1; transform: scale(1); }
  }
  @keyframes progressGrow {
    from { width: 0%; }
  }
  @keyframes ringPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(99,102,241,0.45); }
    50%       { box-shadow: 0 0 0 10px rgba(99,102,241,0); }
  }
  @keyframes shimmer {
    0%   { background-position: -600px 0; }
    100% { background-position: 600px 0; }
  }
  @keyframes toastSlide {
    from { opacity: 0; transform: translateX(-50%) translateY(16px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-8px); }
  }
  @keyframes navDrop {
    from { opacity: 0; transform: translateY(-100%); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .nav-anim { animation: navDrop 0.45s cubic-bezier(0.4,0,0.2,1) both; }

  .fadeUp-1 { animation: fadeUp 0.5s ease both 0.15s; }
  .fadeUp-2 { animation: fadeUp 0.5s ease both 0.22s; }
  .fadeUp-3 { animation: fadeUp 0.5s ease both 0.29s; }
  .fadeUp-4 { animation: fadeUp 0.5s ease both 0.36s; }
  .fadeUp-5 { animation: fadeUp 0.5s ease both 0.43s; }

  .avatar-img  { animation: scaleIn 0.5s ease both 0.1s; }
  .avatar-ring { animation: ringPulse 3s ease infinite; }

  .progress-bar {
    animation: progressGrow 1.4s cubic-bezier(0.4,0,0.2,1) both;
    animation-delay: 0.6s;
  }

  .glass {
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(255,255,255,0.6);
  }

  /* Navbar glass */
  .nav-glass {
    background: rgba(255,255,255,0.82);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.55);
  }

  /* Nav link hover underline */
  .nav-link {
    position: relative;
    transition: color 0.2s ease;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 0;
    width: 0; height: 2px;
    background: linear-gradient(90deg, #6366f1, #8b5cf6);
    border-radius: 2px;
    transition: width 0.25s ease;
  }
  .nav-link:hover::after { width: 100%; }
  .nav-link:hover { color: #6366f1; }
  .nav-link.active { color: #6366f1; }
  .nav-link.active::after { width: 100%; }

  /* Dashboard pill button */
  .btn-dash {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    transition: all 0.22s ease;
    position: relative;
    overflow: hidden;
  }
  .btn-dash::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.14), transparent);
    background-size: 300% 100%;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .btn-dash:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 22px rgba(99,102,241,0.35);
  }
  .btn-dash:hover::after {
    opacity: 1;
    animation: shimmer 1.2s infinite;
  }
  .btn-dash:active { transform: scale(0.98); }

  /* Mobile menu */
  #mobileMenu {
    transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.3s ease;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
  }
  #mobileMenu.open {
    max-height: 300px;
    opacity: 1;
  }

  /* Save button */
  .btn-save {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    transition: all 0.25s ease;
    position: relative;
    overflow: hidden;
  }
  .btn-save::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    background-size: 300% 100%;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .btn-save:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(99,102,241,0.38); }
  .btn-save:hover::after { opacity: 1; animation: shimmer 1.2s infinite; }
  .btn-save:active { transform: scale(0.99); }

  .input-field { transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease; }
  .input-field:focus {
    border-color: #6366f1 !important;
    box-shadow: 0 0 0 4px rgba(99,102,241,0.12);
    background: #fff;
    outline: none;
  }
  .input-field:hover { border-color: #a5b4fc !important; }

  .card-hover { transition: transform 0.25s ease, box-shadow 0.25s ease; }
  .card-hover:hover { transform: translateY(-2px); box-shadow: 0 20px 48px rgba(99,102,241,0.10); }

  .detail-pill { transition: background 0.2s, transform 0.2s; }
  .detail-pill:hover { background: rgba(99,102,241,0.07); transform: scale(1.01); }

  .upload-btn { transition: all 0.2s ease; }
  .upload-btn:hover { background: rgba(99,102,241,0.1); border-color: #6366f1; color: #6366f1; }

  .toast {
    position: fixed;
    bottom: 2rem; left: 50%;
    transform: translateX(-50%);
    animation: toastSlide 0.35s ease both;
    z-index: 999;
    white-space: nowrap;
  }

  .blob1 {
    position: fixed; top: -120px; left: -120px;
    width: 480px; height: 480px;
    background: radial-gradient(circle, rgba(165,180,252,0.35) 0%, transparent 70%);
    border-radius: 50%; pointer-events: none; z-index: 0;
    animation: float 8s ease-in-out infinite;
  }
  .blob2 {
    position: fixed; bottom: -100px; right: -100px;
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(196,181,253,0.3) 0%, transparent 70%);
    border-radius: 50%; pointer-events: none; z-index: 0;
    animation: float 10s ease-in-out infinite reverse;
  }
</style>
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-100 via-indigo-50 to-purple-100">

<div class="blob1"></div>
<div class="blob2"></div>

<!-- ════════════════════════════════════
     NAVBAR
════════════════════════════════════ -->
<nav class="nav-glass sticky top-0 z-50 nav-anim shadow-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <span class="text-base font-bold text-gray-800 tracking-tight group-hover:text-indigo-600 transition-colors duration-200">
          <img src="/images/logo.svg" alt="JOBHUB Logo"
class="h-16 md:h-20 w-auto object-contain">
        </span>
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden sm:flex items-center gap-6">
        <a href="/" class="nav-link text-sm font-medium text-gray-500 flex items-center gap-1.5 py-1">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0h6"/>
          </svg>
          Home
        </a>

        <a href="/profile" class="nav-link active text-sm font-medium text-gray-500 flex items-center gap-1.5 py-1">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          Profile
        </a>

        <a href="/dashboard" class="btn-dash text-white text-sm font-semibold px-4 py-2 rounded-xl flex items-center gap-1.5 shadow">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
          </svg>
          Dashboard
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button onclick="toggleMenu()" class="sm:hidden w-9 h-9 flex flex-col items-center justify-center gap-1.5 rounded-xl hover:bg-indigo-50 transition" id="hamburger">
        <span class="w-5 h-0.5 bg-gray-600 rounded transition-all duration-300" id="hb1"></span>
        <span class="w-5 h-0.5 bg-gray-600 rounded transition-all duration-300" id="hb2"></span>
        <span class="w-5 h-0.5 bg-gray-600 rounded transition-all duration-300" id="hb3"></span>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobileMenu" class="sm:hidden">
      <div class="pb-4 pt-1 space-y-1 border-t border-gray-100">

        <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-gray-600 hover:bg-indigo-50 hover:text-indigo-600 transition-all duration-200">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0h6"/>
          </svg>
          Home
        </a>

        <a href="/profile" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-indigo-600 bg-indigo-50 transition-all duration-200">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          Profile
        </a>

        <a href="/dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-indigo-500 to-purple-600 transition-all duration-200">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
          </svg>
          Dashboard
        </a>

      </div>
    </div>
  </div>
</nav>

<!-- ════════════════════════════════════
     PAGE CONTENT
════════════════════════════════════ -->
<div class="flex justify-center p-4 sm:p-6 pb-20">
<div class="w-full max-w-md space-y-4 relative z-10">

  <!-- ── HERO CARD ── -->
  <div class="glass rounded-3xl p-6 sm:p-8 text-center card-hover fadeUp-1">
    <div class="relative w-28 h-28 mx-auto mb-4">
      <div class="avatar-ring w-28 h-28 rounded-full absolute inset-0 border-2 border-indigo-400"></div>
      <img id="profilePreview"
        src="/uploads/<%= user && user.profilePic ? user.profilePic : 'default.png' %>"
        alt="<%= user.name %>"
        class="avatar-img w-28 h-28 rounded-full object-cover object-top border-4 border-white shadow-lg relative z-10">
      <label class="absolute bottom-1 right-1 z-20 w-8 h-8 bg-indigo-600 hover:bg-indigo-700 text-white rounded-full flex items-center justify-center cursor-pointer shadow-lg transition-all duration-200 hover:scale-110" title="Change photo">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <input type="file" name="profilePic" class="hidden" form="uploadForm" accept="image/*" onchange="previewImage(event)">
      </label>
    </div>

    <h1 class="text-xl font-semibold text-gray-800" id="heroName"><%= user.name %></h1>
    <p class="text-sm text-gray-400 mt-0.5 truncate"><%= user.email %></p>

    <div class="flex items-center justify-center gap-2 mt-3 flex-wrap">
      <span class="inline-flex items-center gap-1 text-xs font-medium px-3 py-1 rounded-full bg-emerald-50 text-emerald-600 border border-emerald-100">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
        Phone Verified
      </span>
      <span class="text-xs font-medium px-3 py-1 rounded-full bg-indigo-50 text-indigo-500 border border-indigo-100">Active</span>
    </div>

    <form id="uploadForm" action="/upload-profile-pic" method="POST" enctype="multipart/form-data" class="mt-5">
      <button type="submit" class="upload-btn text-sm font-medium text-gray-500 border border-gray-200 rounded-xl px-6 py-2 bg-white/60">
        Upload Photo
      </button>
    </form>
  </div>

  <!-- ── PROFILE COMPLETION ── -->
  <div class="glass rounded-2xl p-5 card-hover fadeUp-2">
    <div class="flex justify-between items-center mb-3">
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Profile Completion</p>
      <span class="text-sm font-bold <%= profilePercent < 40 ? 'text-red-500' : profilePercent < 70 ? 'text-amber-500' : 'text-emerald-500' %>">
        <%= profilePercent || 0 %>%
      </span>
    </div>
    <div class="w-full bg-gray-100 rounded-full h-2 overflow-hidden">
      <div class="progress-bar h-2 rounded-full
        <%= profilePercent < 40 ? 'bg-gradient-to-r from-red-400 to-rose-500' :
            profilePercent < 70 ? 'bg-gradient-to-r from-amber-400 to-yellow-500' :
            'bg-gradient-to-r from-emerald-400 to-teal-500' %>"
        style="width:<%= profilePercent || 0 %>%">
      </div>
    </div>
    <p class="text-xs mt-2.5 text-gray-400">
      <% if(profilePercent < 40){ %>Complete your profile to increase visibility
      <% } else if(profilePercent < 80){ %>Almost done — add the remaining details
      <% } else { %>Your profile looks great!<% } %>
    </p>
  </div>

  <!-- ── UPDATE FORM ── -->
  <div class="glass rounded-3xl p-6 card-hover fadeUp-3">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-5">Personal Information</h2>
    <form action="/profile" method="POST" class="space-y-4">

      <div>
        <label class="block text-xs font-medium text-gray-400 mb-1.5">Full Name</label>
        <input type="text" name="name" value="<%= user.name %>"
          placeholder="Your full name"
          oninput="syncName(this.value)"
          class="input-field w-full bg-white/70 border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-800 placeholder-gray-300">
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-400 mb-1.5">Phone Number</label>
        <input type="text" name="phone" value="<%= user.phone || '' %>"
          placeholder="+91 XXXXX XXXXX"
          class="input-field w-full bg-white/70 border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-800 placeholder-gray-300">
        <p class="text-xs text-emerald-500 mt-1.5 flex items-center gap-1">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          Verified
        </p>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1.5">Date of Birth</label>
          <input type="date" name="dob"
            value="<%= user.dob ? user.dob.toISOString().split('T')[0] : '' %>"
            class="input-field w-full bg-white/70 border border-gray-200 rounded-xl px-3 py-2.5 text-sm text-gray-800">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1.5">Marital Status</label>
          <select name="maritalStatus"
            class="input-field w-full bg-white/70 border border-gray-200 rounded-xl px-3 py-2.5 text-sm text-gray-800 cursor-pointer appearance-none">
            <option value="">Select</option>
            <option value="Single"   <%= user.maritalStatus==='Single'   ?'selected':'' %>>Single</option>
            <option value="Married"  <%= user.maritalStatus==='Married'  ?'selected':'' %>>Married</option>
            <option value="Divorced" <%= user.maritalStatus==='Divorced' ?'selected':'' %>>Divorced</option>
            <option value="Widowed"  <%= user.maritalStatus==='Widowed'  ?'selected':'' %>>Widowed</option>
          </select>
        </div>
      </div>

      <button type="submit" class="btn-save w-full text-white font-semibold text-sm py-3 rounded-xl shadow-md mt-1">
        Save Changes
      </button>
    </form>
  </div>

  <!-- ── SUCCESS MESSAGE ── -->
  <% if(locals.query && query.updated){ %>
  <div class="glass rounded-2xl px-5 py-3.5 fadeUp-4 flex items-center justify-center gap-2 text-emerald-600 border border-emerald-100 text-sm font-medium">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
    Profile Updated Successfully
  </div>
  <% } %>

  <!-- ── PROFILE SUMMARY ── -->
  <div class="glass rounded-3xl p-6 card-hover fadeUp-5">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-4">Profile Summary</h2>
    <div class="grid grid-cols-2 gap-2">

      <div class="detail-pill bg-white/50 rounded-2xl px-4 py-3">
        <p class="text-xs text-gray-400 font-medium mb-0.5">Name</p>
        <p class="text-sm font-semibold text-gray-700 truncate" id="summName"><%= user.name %></p>
      </div>

      <div class="detail-pill bg-white/50 rounded-2xl px-4 py-3">
        <p class="text-xs text-gray-400 font-medium mb-0.5">Status</p>
        <p class="text-sm font-semibold text-gray-700"><%= user.maritalStatus || 'Not selected' %></p>
      </div>

      <div class="detail-pill bg-white/50 rounded-2xl px-4 py-3">
        <p class="text-xs text-gray-400 font-medium mb-0.5">Phone</p>
        <p class="text-sm font-semibold text-gray-700 truncate"><%= user.phone || 'Not added' %></p>
      </div>

      <div class="detail-pill bg-white/50 rounded-2xl px-4 py-3">
        <p class="text-xs text-gray-400 font-medium mb-0.5">Date of Birth</p>
        <p class="text-sm font-semibold text-gray-700 text-xs"><%= user.dob ? user.dob.toDateString() : 'Not added' %></p>
      </div>

      <div class="detail-pill bg-white/50 rounded-2xl px-4 py-3 col-span-2">
        <p class="text-xs text-gray-400 font-medium mb-0.5">Email</p>
        <p class="text-sm font-semibold text-gray-700 truncate"><%= user.email %></p>
      </div>

    </div>
  </div>

</div>
</div>

<!-- ── TOAST ── -->
<div id="toast" class="toast hidden">
  <div class="flex items-center gap-2.5 bg-gray-900 text-white text-sm font-medium px-5 py-3 rounded-2xl shadow-2xl">
    <svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
    Profile updated successfully
  </div>
</div>

<script>
  function previewImage(event) {
    const file = event.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => { document.getElementById('profilePreview').src = e.target.result; };
    reader.readAsDataURL(file);
  }

  function syncName(val) {
    const v = val.trim() || 'User';
    document.getElementById('heroName').textContent = v;
    document.getElementById('summName').textContent = v;
  }

  function showToast() {
    const t = document.getElementById('toast');
    t.classList.remove('hidden');
    setTimeout(() => {
      t.style.transition = 'opacity 0.3s ease';
      t.style.opacity = '0';
      setTimeout(() => { t.classList.add('hidden'); t.style.opacity = ''; }, 350);
    }, 3200);
  }

  // Mobile hamburger toggle
  let menuOpen = false;
  function toggleMenu() {
    menuOpen = !menuOpen;
    const menu = document.getElementById('mobileMenu');
    const hb1 = document.getElementById('hb1');
    const hb2 = document.getElementById('hb2');
    const hb3 = document.getElementById('hb3');
    menu.classList.toggle('open', menuOpen);
    if (menuOpen) {
      hb1.style.transform = 'translateY(6px) rotate(45deg)';
      hb2.style.opacity = '0';
      hb3.style.transform = 'translateY(-6px) rotate(-45deg)';
    } else {
      hb1.style.transform = '';
      hb2.style.opacity = '';
      hb3.style.transform = '';
    }
  }

  (function () {
    if (new URLSearchParams(window.location.search).get('updated')) showToast();
  })();
</script>
</body>
</html>
