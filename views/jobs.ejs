<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jobs | JobHub</title>
  <link rel="icon" href="images/jobhub_favicon.ico" type="image/x-icon">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen flex flex-col overflow-x-hidden relative">

<!-- Background Image -->
<div class="absolute inset-0 -z-10">
  <img src="https://wallpapershome.com/images/pages/pic_h/26421.jpg" 
       class="w-full h-full object-cover opacity-40" />
</div>

<!-- Gradient Dark Overlay (IMPORTANT) -->
<div class="absolute inset-0 -z-10 bg-gradient-to-br from-black/80 via-black/60 to-black/80"></div>
<!-- HEADER -->
<nav class="bg-white/95 backdrop-blur-lg shadow-sm sticky top-0 z-50 border-b">
  <div class="max-w-7xl mx-auto px-6 py-3 flex justify-between items-center">

    <!-- LOGO -->
    <div class="flex items-center">
      <img src="/images/logo.svg" alt="JOBHUB Logo"
      class="h-16 md:h-20 w-auto object-contain">
    </div>

    <!-- MENU -->
    <div class="space-x-6 hidden md:flex items-center text-gray-700 font-medium">

<a href="/" class="hover:text-indigo-600 transition">Home</a>
<a href="/jobs" class="hover:text-indigo-600 transition">Jobs</a>

<% if(!user){ %>

<a href="/login" class="hover:text-indigo-600 transition">Login</a>

<a href="/register"
class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-500 transition">
Register
</a>

<% } else { %>

<a href="/user-dashboard"
class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-500 transition">
Account
</a>

<button onclick="openLogoutModal()"
class="border border-red-500 text-red-500 px-4 py-2 rounded-lg hover:bg-red-500 hover:text-white transition">
Logout
</button>

<% } %>

</div>

    <!-- MOBILE BUTTON -->
    <button id="menuBtn" class="md:hidden text-2xl text-gray-700">
      ☰
    </button>

  </div>
</nav>
<!-- MOBILE MENU -->
<div id="mobileMenu"
class="hidden md:hidden absolute right-6 top-20 w-64 bg-white rounded-xl shadow-lg p-4 space-y-4 text-center z-50">

<a href="/" class="block hover:text-indigo-600">Home</a>
<a href="/jobs" class="block hover:text-indigo-600">Jobs</a>

<% if(!user){ %>

<a href="/login" class="block hover:text-indigo-600">Login</a>
<a href="/register" class="block bg-indigo-600 text-white py-2 rounded-lg">
Register
</a>

<% } else { %>

<a href="/user-dashboard" class="block hover:text-indigo-600">
Account
</a>

<button onclick="openLogoutModal()" class="block text-red-500 w-full">
Logout
</button>

<% } %>

</div>
<!-- TITLE -->
<div class="text-center py-16 relative">
  <div class="absolute left-1/2 -translate-x-1/2 w-[400px] h-[400px] bg-indigo-400 opacity-20 blur-3xl rounded-full"></div>

 <h1 class="text-5xl md:text-6xl font-extrabold text-white relative z-10 
           tracking-tight drop-shadow-[0_5px_20px_rgba(0,0,0,0.8)]">

  Explore Jobs 🚀
</h1>
  <p class="text-gray-300 mt-4 text-lg relative z-10">
  Find opportunities that match your skills
</p>
</div>

<!-- JOB LIST -->
<div class="max-w-7xl mx-auto px-6 pb-20 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">

<% jobs.forEach(job=>{ %>

<div class="group relative bg-white/10 backdrop-blur-lg p-6 md:p-8 rounded-2xl 
            border border-white/20 shadow-lg hover:shadow-2xl 
            transition duration-500 transform hover:-translate-y-2 hover:scale-[1.02] 
            flex flex-col justify-between overflow-hidden">

  <!-- Glow Effect -->
  <div class="absolute inset-0 pointer-events-none 
              bg-gradient-to-r from-indigo-400/0 via-indigo-400/20 to-indigo-400/0 
              opacity-0 group-hover:opacity-100 transition duration-500"></div>

  <div>
    <!-- Title -->
    <h2 class="text-xl md:text-2xl font-semibold text-white leading-snug 
               group-hover:text-yellow-400 transition">
      <%= job.title %>
    </h2>

    <!-- Company -->
    <p class="text-gray-200 mt-2 text-base font-medium">
      🏢 <%= job.company %>
    </p>

    <!-- Location -->
    <p class="text-sm text-gray-300 mt-1">
      📍 <%= job.location %>
    </p>
  </div>

  <!-- Footer -->
  <div class="mt-6 flex items-center justify-between">
    <a href="/jobs/<%= job._id %>"
      class="relative z-10 px-5 py-2.5 rounded-lg 
             bg-indigo-500 text-white text-sm font-medium 
             hover:bg-indigo-400 transition shadow-md hover:shadow-lg">
      View Details →
    </a>

    <span class="text-xs text-white bg-white/10 px-2 py-1 rounded-full border border-white/20">
      New
    </span>
  </div>

</div>

<% }) %>

</div>

<!-- EXTRA SECTION -->
<section class="max-w-7xl mx-auto px-6 py-20 grid md:grid-cols-3 gap-8">

<div class="bg-white/80 backdrop-blur-lg p-6 rounded-2xl shadow-md text-center border border-gray-200 hover:shadow-xl transition transform hover:-translate-y-2">
  <h3 class="text-xl font-semibold text-gray-900">💼 1000+ Jobs</h3>
  <p class="text-gray-500 mt-2">Daily new opportunities</p>
</div>

<div class="bg-white/80 backdrop-blur-lg p-6 rounded-2xl shadow-md text-center border border-gray-200 hover:shadow-xl transition transform hover:-translate-y-2">
  <h3 class="text-xl font-semibold text-gray-900">🚀 Fast Apply</h3>
  <p class="text-gray-500 mt-2">Apply in just one click</p>
</div>

<div class="bg-white/80 backdrop-blur-lg p-6 rounded-2xl shadow-md text-center border border-gray-200 hover:shadow-xl transition transform hover:-translate-y-2">
  <h3 class="text-xl font-semibold text-gray-900">🔒 Secure</h3>
  <p class="text-gray-500 mt-2">Your data is safe</p>
</div>

</section>

<!-- EMPTY -->
<% if(jobs.length === 0){ %>
<div class="text-center text-gray-500 pb-20">
  <p class="text-lg">😔 No jobs found</p>
</div>
<% } %>

<!-- FOOTER -->
<footer class="bg-gray-900 text-gray-300 text-center py-6 mt-auto">
  <p>© 2026 JobPortal. All rights reserved.</p>
</footer>

<div id="logoutModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center">

  <div class="bg-white p-6 rounded-xl text-center animate-scale">

    <h2 class="text-lg font-semibold">Logout?</h2>
    <p class="text-gray-500 mt-2">Are you sure you want to logout?</p>

    <div class="flex justify-center gap-4 mt-4">

      <button onclick="closeLogoutModal()"
      class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">
        Cancel
      </button>

       <a href="/logout"
class="px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600">
Logout
</a>

    </div>

  </div>

</div>

</body>

<script>
const btn = document.getElementById("menuBtn");
const menu = document.getElementById("mobileMenu");

// toggle open/close
btn.addEventListener("click", (e) => {
  e.stopPropagation();
  menu.classList.toggle("hidden");
});

// click outside = close
document.addEventListener("click", (e) => {
  if (!menu.contains(e.target) && !btn.contains(e.target)) {
    menu.classList.add("hidden");
  }
});

function openLogoutModal(){
document.getElementById("logoutModal").classList.remove("hidden")
document.getElementById("logoutModal").classList.add("flex")
}

function closeLogoutModal(){
document.getElementById("logoutModal").classList.add("hidden")
}
</script>
</html>