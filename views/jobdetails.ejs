<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= job.title %> | JobHub</title>
<link rel="icon" href="/images/jobhub_favicon.ico">

<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="relative min-h-screen">

<!-- NAVBAR -->
<nav class="bg-white/95 backdrop-blur-lg fixed w-full z-50 border-b">
<div class="max-w-7xl mx-auto px-6 py-3 flex justify-between items-center">

<img src="/images/logo.svg" class="h-14 md:h-16">

<div class="space-x-6 hidden md:flex items-center">
<a href="/" class="hover:text-indigo-600">Home</a>
<a href="/jobs" class="hover:text-indigo-600">Jobs</a>

<% if(!user){ %>
<a href="/login" class="hover:text-indigo-600">Login</a>
<a href="/register" class="bg-indigo-600 text-white px-5 py-2 rounded-lg">Register</a>
<% } else { %>
<a href="/user-dashboard" class="bg-indigo-600 text-white px-5 py-2 rounded-lg">
Dashboard
</a>
<% } %>

</div>

</div>
</nav>

<!-- BACKGROUND -->
<div class="fixed inset-0 -z-10">
  <img src="https://images.unsplash.com/photo-1521791136064-7986c2920216"
  class="w-full h-full object-cover">
  <div class="absolute inset-0 bg-black/60"></div>
</div>

<!-- CONTENT -->
<div class="max-w-5xl mx-auto px-6 pt-32 pb-12">

<!-- JOB CARD -->
<div class="bg-white/95 backdrop-blur rounded-2xl shadow-xl p-8">

<h1 class="text-3xl md:text-4xl font-bold text-gray-800">
<%= job.title %>
</h1>

<p class="text-gray-600 mt-2 text-lg">
🏢 <%= job.company %>
</p>

<div class="flex flex-wrap gap-3 mt-4">

<span class="bg-gray-100 px-4 py-2 rounded-lg text-sm">
📍 <%= job.location %>
</span>

<span class="bg-green-100 text-green-700 px-4 py-2 rounded-lg text-sm font-semibold">
💰 ₹ <%= job.salary %>
</span>

</div>

<div class="mt-6 border-t pt-6">
<h2 class="text-xl font-semibold mb-2">Job Description</h2>
<p class="text-gray-700 leading-relaxed">
<%= job.description %>
</p>
</div>

</div>

<!-- APPLY SECTION -->
<div class="bg-white/95 backdrop-blur rounded-2xl shadow-xl p-8 mt-8 text-center">

<h2 class="text-2xl font-semibold mb-6 text-gray-800">
Apply for this job 🚀
</h2>

<% if(job.applyLink){ %>

<!-- 🌍 EXTERNAL APPLY -->
<p class="text-gray-600 mb-4">
Apply directly on company website
</p>

<a href="<%= job.applyLink %>" target="_blank"
class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-500 transition">
Apply on Website 🌍
</a>

<% } else { %>

  <% if(!user){ %>

  <!-- LOGIN REQUIRED -->
  <div class="bg-yellow-50 border border-yellow-200 p-6 rounded-xl">

    <p class="text-gray-700 mb-4">
      ⚠️ Please login to apply
    </p>

    <a href="/login"
    class="bg-indigo-600 text-white px-6 py-2 rounded-lg">
      Login
    </a>

  </div>

  <% } else { %>

  <!-- NORMAL APPLY -->
  <form action="/apply/<%= job._id %>" method="POST" enctype="multipart/form-data" class="space-y-5">

    <input type="file" name="resume" required
    class="w-full border p-3 rounded-lg">

    <button
    class="w-full bg-indigo-600 text-white py-3 rounded-lg hover:bg-indigo-500 transition">
      Apply Now 🚀
    </button>

  </form>

  <% } %>

<% } %>

</div>

<!-- FOOTER TEXT -->
<p class="text-center text-sm text-gray-300 mt-6">
We review applications carefully and contact shortlisted candidates.
</p>

</div>

</body>
</html>