<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Dashboard | JobHub</title>
<link rel="icon" href="/images/jobhub_favicon.ico">

<script src="https://cdn.tailwindcss.com"></script>

<style>
@keyframes scaleIn{
from{transform:scale(.85);opacity:0}
to{transform:scale(1);opacity:1}
}
.animate-scale{
animation:scaleIn .25s ease;
}

/* gradient divider */
.divider{
height:4px;
background:linear-gradient(to right,#6366f1,#ec4899,#facc15);
border-radius:10px;
margin:40px 0;
}
</style>
</head>

<body class="bg-gradient-to-br from-gray-100 to-gray-200 min-h-screen flex flex-col">

<!-- HEADER -->
<header class="bg-white/90 backdrop-blur border-b sticky top-0 z-50">
<div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">

<a href="/">
<img src="/images/logo.svg" class="w-36">
</a>

<div class="flex items-center gap-4">

<div class="bg-gray-100 px-3 py-1 rounded-lg shadow-sm">
👤 <%= user.name %>
</div>

<a href="/post-job"
class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-500 transition shadow">
+ Post Job
</a>

<button onclick="openLogoutModal()"
class="border border-red-500 text-red-500 px-4 py-2 rounded-lg hover:bg-red-500 hover:text-white transition">
Logout
</button>

</div>
</div>
</header>

<!-- MAIN -->
<div class="flex-1 max-w-6xl mx-auto px-6 py-10 w-full">

<!-- <h1 class="text-4xl font-bold text-center mb-12 text-gray-800">
✨ My Dashboard
</h1> -->

<!-- TITLE -->
<h1 class="text-4xl font-bold text-center mb-12 fade-up">
🚀 Welcome, <span class="text-indigo-600"><%= user.name %></span>
</h1>

<!-- ================= MY POSTED JOBS ================= -->

<div class="bg-white p-6 rounded-xl shadow-lg">

<h2 class="text-3xl text-center font-semibold mb-6 text-indigo-600">
💼 Posted Jobs
</h2>

<% if(myJobs.length === 0){ %>

<div class="text-center py-12">

  <!-- Icon -->
  <div class="text-6xl mb-4">
    📂
  </div>

  <!-- Heading -->
  <h2 class="text-2xl font-semibold text-gray-700">
    No Jobs Posted Yet
  </h2>

  <!-- Description -->
  <p class="text-gray-500 mt-2 max-w-md mx-auto">
    You haven’t posted any job opportunities yet. Start hiring by creating your first job post.
  </p>

  <!-- Button -->
  <a href="/post-job"
  class="inline-block mt-6 bg-indigo-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-indigo-500 transition shadow">
    + Post Your First Job
  </a>

</div>

<% } else { %>

<div class="grid md:grid-cols-2 gap-6">

<% myJobs.forEach(job=>{ %>

<div class="bg-gray-50 p-5 rounded-xl shadow hover:shadow-lg transition transform hover:-translate-y-1">

<h3 class="font-semibold text-lg text-gray-800">💼 <%= job.title %></h3>
<p class="text-gray-600">🏢 <%= job.company %></p>
<p class="text-gray-500 text-sm">📍 <%= job.location %></p>

<div class="flex flex-wrap gap-3 mt-4">

<a href="/jobs/<%= job._id %>"
class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 text-sm">
View Details
</a>

<a href="/edit-job/<%= job._id %>"
class="bg-indigo-500 text-white px-4 py-2 rounded hover:bg-indigo-600 text-sm">
Edit
</a>

<button onclick="confirmDelete('<%= job._id %>')"
class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 text-sm">
Delete
</button>

<a href="/applicants/<%= job._id %>"
class="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600 text-sm">
Applicants
</a>

</div>

</div>

<% }) %>

</div>

<% } %>

</div>

<!-- 🔥 DIVIDER -->
<div class="divider"></div>

<!-- ================= MY APPLICATIONS ================= -->

<div class="bg-white p-6 rounded-xl shadow-lg">

<h2 class="text-3xl text-center font-semibold mb-6 text-pink-600">
📄 My Applications
</h2>

<% if(applications.length === 0){ %>

<div class="text-center text-gray-500">
No Applications Yet
</div>

<% } else { %>

<div class="grid md:grid-cols-2 gap-6">

<% applications.forEach(app=>{ %>

<div class="bg-gray-50 p-5 rounded-xl shadow hover:shadow-lg transition">

<h3 class="font-semibold text-lg text-gray-800">
💼 <%= app.jobId.title %>
</h3>

<p class="text-gray-600">
🏢 <%= app.jobId.company %>
</p>

<p class="text-gray-500 text-sm">
📍 <%= app.jobId.location %>
</p>



<!-- STATUS -->
<div class="mt-3">

<span class="px-3 py-1 text-xs rounded font-semibold
<%= app.status === 'Shortlisted' ? 'bg-green-100 text-green-700' :
app.status === 'Rejected' ? 'bg-red-100 text-red-700' :
'bg-yellow-100 text-yellow-700' %>">

<%= app.status %>

</span>

<!-- MESSAGE -->
<p class="text-sm mt-2 text-gray-600">

<% if(app.status === 'Shortlisted'){ %>
🎉 Congratulations! Our HR team will contact you shortly.
<% } else if(app.status === 'Rejected'){ %>
💙 Thank you for applying. We encourage you to explore more opportunities.
<% } else { %>
⏳ Your application is under review.
<% } %>

</p>

</div>

</div>

<% }) %>

</div>

<% } %>

</div>
<!-- BROWSE JOB BUTTON -->
<div class="text-center mt-10">

  <a href="/jobs"
  class="inline-flex items-center gap-2 bg-indigo-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-indigo-500 transition shadow-lg hover:scale-105">

    🔍 Browse Jobs

  </a>

</div>

</div>

<!-- FOOTER -->
<footer class="bg-gray-900 text-gray-400 mt-10">

<div class="max-w-6xl mx-auto px-6 py-10 text-center">

<h2 class="text-white text-lg font-semibold mb-2">
JobHub Dashboard
</h2>

<p class="text-sm">
Manage your jobs and applications easily with our smart dashboard.
</p>

<p class="mt-4 text-xs text-gray-500">
© 2026 JobHub • All rights reserved
</p>

</div>

</footer>

<!-- LOGOUT MODAL -->
<div id="logoutModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center">

  <div class="bg-white p-6 rounded-xl text-center animate-scale">

    <h2 class="text-lg font-semibold">Logout?</h2>
    <p class="text-gray-500 mt-2">Are you sure you want to logout?</p>

    <div class="flex justify-center gap-4 mt-4">

      <button onclick="closeLogoutModal()"
      class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">
        Cancel
      </button>

      <a href="/logout"
      class="px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600">
        Logout
      </a>

    </div>

  </div>

</div>

<!-- MODALS SAME -->
<script>

function openLogoutModal(){
document.getElementById("logoutModal").classList.remove("hidden")
document.getElementById("logoutModal").classList.add("flex")
}

function closeLogoutModal(){
document.getElementById("logoutModal").classList.add("hidden")
}

function confirmDelete(id){
document.getElementById("deleteModal").classList.remove("hidden")
document.getElementById("deleteModal").classList.add("flex")
document.getElementById("deleteLink").href = "/delete-job/" + id
}

function closeDeleteModal(){
document.getElementById("deleteModal").classList.add("hidden")
}

</script>

</body>
</html>